OPENAI_API_KEY=sk-...

# API access guard.
# Local Netlify dev allows unauthenticated requests by default.
# Deployed functions require one of these tokens unless PUENTES_PUBLIC_API=true is set.
PUENTES_API_TOKEN=
# PUENTES_API_TOKENS=token-one,token-two
# PUENTES_REQUIRE_API_AUTH=true
# PUENTES_PUBLIC_API=false
# PUENTES_ALLOW_NETLIFY_IDENTITY=false
# PUENTES_ALLOWED_NETLIFY_ROLES=admin,editor
# PUENTES_AI_RATE_LIMIT=12
# PUENTES_DOWNLOAD_RATE_LIMIT=20
# PUENTES_MUTATION_RATE_LIMIT=60
# PUENTES_RATE_LIMIT_WINDOW_MS=60000
# PUENTES_VIDEO_DOWNLOAD_MAX_BYTES=4500000

PUENTES_TEXT_MODEL=gpt-5
PUENTES_TEXT_MODELS=gpt-5,gpt-5-mini
PUENTES_REVIEW_MODEL=gpt-5-mini
PUENTES_REVIEW_MODELS=gpt-5-mini,gpt-5
PUENTES_IMAGE_MODEL=gpt-image-1.5
PUENTES_IMAGE_MODELS=gpt-image-1.5
PUENTES_VIDEO_MODEL=sora-2
PUENTES_VIDEO_MODELS=sora-2

# Optional: local Netlify/file-backed demo persistence.
# On deployed Netlify, use a real database or keep the frontend in local demo mode.
PUENTES_STORE_BACKEND=file
